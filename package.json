{
	"name": "ytkn",
	"version": "1.6.4",
	"description": "Create structured knowledge notes from YouTube videos inside Obsidian.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node scripts/build.mjs",
		"lint:full": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest --run",
		"verify": "npm run lint:full && npm run typecheck && npm run test:run && npm audit --audit-level=moderate && npm run build",
		"sync": "node sync.mjs",
		"release:prep": "npm version --no-git-tag-version",
		"release:check": "node scripts/verify-release.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"youtube",
		"knowledge-notes",
		"summarizer",
		"ai",
		"transcript"
	],
	"author": "aawhb",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aawhb/ytkn.git"
	},
	"bugs": {
		"url": "https://github.com/aawhb/ytkn/issues"
	},
	"homepage": "https://github.com/aawhb/ytkn#readme",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@eslint/json": "^0.14.0",
		"@types/node": "^25.7.0",
		"@vitest/coverage-v8": "^4.1.6",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.0",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"fast-check": "^4.8.0",
		"jsdom": "^29.1.1",
		"obsidian": "^1.12.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.95.2",
		"@google/generative-ai": "^0.24.1",
		"openai": "^6.37.0"
	}
}
