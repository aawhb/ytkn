# The absolute path to your Obsidian vault root.
# npm run sync copies files into .obsidian/plugins/ytkn automatically.
# Windows example: C:\Users\a\Documents\MyVault
# macOS/Linux example: /home/user/Documents/MyVault
OBSIDIAN_VAULT_PATH=

# Optional: plugin = obsidian plugin:reload id=ytkn, app = obsidian reload, none = copy only.
# Enable CLI in Obsidian Settings → General, then restart your terminal.
OBSIDIAN_SYNC_RELOAD=plugin
